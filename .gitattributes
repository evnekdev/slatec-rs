# Profile compatibility providers are hashed into deterministic native metadata.
# Keep their working-tree bytes stable on the supported Windows GNU profile.
native/profile/gnu-mingw-x86_64/*.f text eol=lf

# Deterministic generated safe-API records and their maintained examples.
generated/safe-api/*.json text eol=lf
generated/safe-api/*.md text eol=lf
docs/api/*.md text eol=lf
examples/**/*.rs text eol=lf
