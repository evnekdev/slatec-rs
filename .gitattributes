# Keep all textual working-tree files in one deterministic form.  This prevents
# generated artifacts from acquiring CRLF-only changes on Windows before a PR.
* text=auto eol=lf

# Profile compatibility providers are hashed into deterministic native metadata.
# Keep their working-tree bytes stable on the supported Windows GNU profile.
native/profile/gnu-mingw-x86_64/*.f text eol=lf

# Deterministic generated safe-API records and their maintained examples.
generated/safe-api/*.json text eol=lf
generated/safe-api/*.md text eol=lf
# Batch A generator outputs must compare byte-for-byte from clean Windows roots.
generated/raw-api/*.json text eol=lf
generated/raw-api/*.md text eol=lf
generated/linkage/batch-a-linkage-report.json text eol=lf
crates/slatec-sys/src/batch_a/*.rs text eol=lf
crates/slatec-sys/tests/batch_a_compile_*.rs text eol=lf
crates/slatec/tests/raw_batch_a_link_*.rs text eol=lf
# Native-link reports are regenerated byte-for-byte across clean Windows roots.
generated/native-link/*.json text eol=lf
generated/native-link/*.md text eol=lf
docs/api/*.md text eol=lf
examples/**/*.rs text eol=lf
